PORT=8787
LLM_PROVIDER=openai
OPENAI_API_KEY=your_openai_key
OPENAI_MODEL=gpt-4.1-mini
ANTHROPIC_API_KEY=your_anthropic_key
ANTHROPIC_MODEL=claude-3-5-sonnet-20241022

SYSTEM_PROMPT_PATH=./config/systemPrompt.txt
SYSTEM_PROMPT=

CORS_ORIGIN=https://muntasir-mamun7.github.io

TELEGRAM_BOT_TOKEN=your_telegram_bot_token
TELEGRAM_ADMIN_CHAT_ID=123456789

CHROMA_URL=http://localhost:8000
CHROMA_COLLECTION=morn-knowledge
RAG_TOP_K=4
MAX_HISTORY=8

HANDOVER_MESSAGE=The Architect has entered the terminal. I am shifting to observer mode to allow for direct synchronization.
RETURN_MESSAGE=The Architect has stepped back. I am resuming autonomous guidance.

OPENAI_EMBEDDING_MODEL=text-embedding-3-small
CHROMA_PERSIST_DIR=./rag/chroma
RAG_DATA_DIR=./rag/data
